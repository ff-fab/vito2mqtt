# vito2mqtt Configuration Template for Docker Deployment
#
# Copy this file to .env and customize values for your environment.
#
# Configuration priority (highest to lowest):
#   1. Environment variables (VITO2MQTT_* prefix)
#   2. .env file (this file, loaded by docker-compose)
#   3. Application defaults
#
# See docs/reference/configuration.md for detailed option documentation.

# ============================================================================
# Serial Connection Configuration
# ============================================================================
# Connection to Viessmann heating device via Optolink P300 protocol

# Serial port device path
# - Linux: /dev/ttyUSB0, /dev/ttyUSB1, /dev/ttyACM0
# - macOS: /dev/tty.usbserial-*, /dev/tty.usbmodem*
# - Windows: COM3, COM4, etc. (Windows paths not recommended for Docker)
VITO2MQTT_SERIAL_PORT=/dev/ttyUSB0

# Serial port baud rate (P300 protocol uses fixed 4800)
VITO2MQTT_SERIAL_BAUD_RATE=4800

# ============================================================================
# MQTT Broker Configuration
# ============================================================================
# Connection to MQTT broker for publishing telemetry and receiving commands

# Broker hostname or IP address
# - Docker Compose: use service name 'mosquitto'
# - External broker: use hostname or IP (e.g., 192.168.1.100)
VITO2MQTT_MQTT__HOST=mosquitto

# Broker port (default MQTT: 1883, MQTT over TLS: 8883)
VITO2MQTT_MQTT__PORT=1883

# MQTT credentials (uncomment if broker requires authentication)
# VITO2MQTT_MQTT__USERNAME=mqtt_user
# VITO2MQTT_MQTT__PASSWORD=mqtt_pass

# ============================================================================
# Device and Signal Configuration
# ============================================================================
# Identity and language settings for the heating device

# Device identifier (alphanumeric, no spaces)
# Used in MQTT topic prefix: vito2mqtt/<DEVICE_ID>/telemetry
# Example: vitodens200w, heating-system, boiler-1
VITO2MQTT_DEVICE_ID=vitodens200w

# Signal name language (ISO 639-1 code)
# - en: English
# - de: German
VITO2MQTT_SIGNAL_LANGUAGE=en

# ============================================================================
# Polling Intervals (seconds)
# ============================================================================
# How often to poll each telemetry group from the heating device
# Shorter intervals = more frequent updates, higher CPU/network load
# Longer intervals = less responsive, lower resource consumption

# Outdoor temperature (weather sensing)
VITO2MQTT_POLLING_OUTDOOR=300

# Hot water boiler temperatures, status
VITO2MQTT_POLLING_HOT_WATER=300

# Burner status, flame detection, ignition attempts
VITO2MQTT_POLLING_BURNER=300

# Radiator heating loop (flow/return temps, pump speed)
VITO2MQTT_POLLING_HEATING_RADIATOR=300

# Floor heating loop (if applicable)
VITO2MQTT_POLLING_HEATING_FLOOR=300

# System-level diagnostics, runtime hours, kW output
VITO2MQTT_POLLING_SYSTEM=3600

# Extended diagnostics and error codes (less frequent)
VITO2MQTT_POLLING_DIAGNOSIS=300

# ============================================================================
# Legionella Treatment Configuration (optional)
# ============================================================================
# Periodic hot water tank temperature boost to prevent legionella growth
# Disabled if all values are omitted

# Target water temperature (°C) for legionella treatment
VITO2MQTT_LEGIONELLA_TEMPERATURE=68

# Treatment duration (minutes)
VITO2MQTT_LEGIONELLA_DURATION_MINUTES=40

# Safety margin before target (minutes)
# Heating starts this many minutes before scheduled treatment time
VITO2MQTT_LEGIONELLA_SAFETY_MARGIN_MINUTES=30

# ============================================================================
# State Persistence (optional)
# ============================================================================
# Path to the JSON store file for device state (legionella timestamps, etc.)
# Default: ~/.local/state/vito2mqtt/store.json (XDG Base Directory)
# Docker: Set to /data/store.json with a named volume (docker-compose.yml does this)
# VITO2MQTT_STORE_PATH=/data/store.json

# ============================================================================
# Logging Configuration
# ============================================================================

# Log level (trace, debug, info, warning, error, critical)
# - trace/debug: Very verbose, includes protocol frames for debugging
# - info: Normal operation logging (recommended for production)
# - warning: Only report issues
# - error: Only report errors and critical failures
VITO2MQTT_LOGGING__LEVEL=INFO

# Log format (optional)
# - text: Human-readable format (default)
# - json: Structured JSON (better for log aggregation)
# VITO2MQTT_LOGGING__FORMAT=text
